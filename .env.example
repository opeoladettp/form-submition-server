# ─── Gmail SMTP ───────────────────────────────────────────────
# Your Gmail address (the one with the App Password)
GMAIL_USER=youremail@gmail.com

# Google App Password (16-char, no spaces)
# Get one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASS=your_app_password_here

# ─── Security ─────────────────────────────────────────────────
# Generate any strong random string to use as your API key
# e.g. run in terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=your_strong_api_key_here

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your website domains)
# Use exact origins including protocol, no trailing slash
ALLOWED_ORIGINS=https://assurancebyjummy.com.ng,https://www.assurancebyjummy.com.ng

# ─── Server ───────────────────────────────────────────────────
PORT=3000
